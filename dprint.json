{
  "lineWidth": 120,
  "newLineKind": "lf",
  "useTabs": false,
  "incremental": true,
  "typescript": {
    "deno": true,
    "lineWidth": 120
  },
  "json": { "deno": true },
  "yaml": {},
  "toml": {},
  "markdown": {
    "deno": true
  },
  "csharpier": {},
  "exec": {
    "commands": [
      { "command": "gofmt", "stdin": true, "exts": ["go"] }
    ]
  },
  "includes": [
    "**/*.{cs,go,ts,tsx,js,jsx,cjs,mjs,json,yml,yaml,toml,md}"
  ],
  "excludes": [
    "**/.git",
    "**/.pixi",
    "CHANGELOG.md"
  ],
  "plugins": [
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/typescript-0.96.1.wasm",
    "https://plugins.dprint.dev/json-0.22.0.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/exec-0.7.2.json@6c30bd00dfb176774ece412d0fbf149478269ecc92c55ab2d6f4116938ed993e",
    "https://plugins.dprint.dev/Phault/csharpier-0.2.2.json@7ee18eb6f024b77dbba765af61bc5024fc699814797f909715820fd8eeab4ca5"
  ]
}
